generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  name      String?  @db.VarChar(255)
  phone     String?  @unique @db.VarChar(20)
  role      UserRole @default(USER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders            Order[]
  passwordResetOtps PasswordResetOtp[]

  @@map("users")
}

model PasswordResetOtp {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  otpHash   String    @map("otp_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_otps")
}

model Order {
  id              Int            @id @default(autoincrement())
  orderNumber     String         @unique @map("order_number") @db.VarChar(32)
  userId          Int            @map("user_id")
  status          OrderStatus    @default(PENDING)
  paymentMethod   PaymentMethod  @default(COD) @map("payment_method")
  phone           String         @db.VarChar(20)
  shippingName    String         @map("shipping_name") @db.VarChar(255)
  shippingAddress String         @map("shipping_address") @db.Text
  city            String         @db.VarChar(100)
  state           String?        @db.VarChar(100)
  pincode         String         @db.VarChar(20)
  notes           String?        @db.Text
  subtotal        Decimal        @db.Decimal(10, 2)
  totalMrp        Decimal        @map("total_mrp") @db.Decimal(10, 2)
  totalSavings    Decimal        @map("total_savings") @db.Decimal(10, 2)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  orderId    Int     @map("order_id")
  productId  Int     @map("product_id")
  name       String  @db.VarChar(500)
  mindHealNo String  @map("mind_heal_no") @db.VarChar(20)
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)
  unitMrp    Decimal @map("unit_mrp") @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model BlogCategory {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  posts         Post[]
  postsCategory PostsCategory[]

  @@map("blog_category")
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(500)
  slug        String    @unique @db.VarChar(500)
  excerpt     String?   @db.Text
  content     String    @db.LongText
  image       String?   @db.VarChar(500)
  author      String?   @db.VarChar(255)
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  categoryId  Int?      @map("category_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  category      BlogCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  postsCategory PostsCategory[]

  @@index([categoryId])
  @@index([published])
  @@map("posts")
}

model PostsCategory {
  postId     Int @map("post_id")
  categoryId Int @map("category_id")

  post     Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("posts_category")
}

model Product {
  id             Int      @id @default(autoincrement())
  mindHealNo     String   @map("mind_heal_no") @db.VarChar(20)
  name           String   @db.VarChar(500)
  slug           String   @unique @db.VarChar(500)
  description      String?  @db.LongText
  shortDescription String?  @map("short_description") @db.Text
  mrp              Decimal  @default(400) @db.Decimal(10, 2)
  price            Decimal  @default(250) @map("discounted_price") @db.Decimal(10, 2)
  image            String?  @db.VarChar(500)
  published      Boolean  @default(true)
  sortOrder      Int      @default(0) @map("sort_order")
  emotionalTags  String?  @map("emotional_tags") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@unique([mindHealNo])
  @@index([published])
  @@map("product")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  content   String   @db.Text
  image     String?  @db.VarChar(500)
  rating    Int?     @default(5)
  published Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@map("testimonials")
}

model HomeSlide {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(500)
  subtitle  String?  @db.Text
  image     String   @db.VarChar(500)
  published Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@map("home_slides")
}

model TeamMember {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  degree       String?  @db.VarChar(255)
  experience   String?  @db.VarChar(100)
  image        String?  @db.VarChar(500)
  bio          String?  @db.Text
  expertise    String?  @db.LongText
  portfolio    String?  @db.LongText
  facebookUrl  String?  @map("facebook_url") @db.VarChar(500)
  twitterUrl   String?  @map("twitter_url") @db.VarChar(500)
  linkedinUrl  String?  @map("linkedin_url") @db.VarChar(500)
  instagramUrl String?  @map("instagram_url") @db.VarChar(500)
  published    Boolean  @default(true)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@map("team_members")
}
