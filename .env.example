# Public website URL (used on printed delivery QR codes)
VITE_SITE_URL=https://your-domain.com

# Public API URL (browser + optional SSR). Must include /api path or host only.
# Example: https://api.your-domain.com/api  OR  https://api.your-domain.com
VITE_API_URL=https://api.your-domain.com/api

# Server-side only (Vercel). Same as VITE_API_URL if API is on another host.
# Omit if you use vercel.json rewrites so /api on your site proxies to the backend.
# API_INTERNAL_URL=https://api.your-domain.com/api
